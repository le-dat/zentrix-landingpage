---
import { t, getLocale } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

const locale: Locale = getLocale(Astro.request.url);
---

<section id="how-it-works" class="py-24 md:py-32 bg-[#0f1619] relative overflow-hidden">

  <!-- Animated dot grid background -->
  <div class="absolute inset-0 opacity-[0.15]" aria-hidden="true">
    <div class="dot-grid"></div>
  </div>

  <!-- Ambient glow orbs -->
  <div class="absolute top-1/4 -left-32 w-64 h-64 bg-[#9fe870]/5 rounded-full blur-3xl" aria-hidden="true"></div>
  <div class="absolute bottom-1/4 -right-32 w-64 h-64 bg-[#9fe870]/5 rounded-full blur-3xl" aria-hidden="true"></div>

  <div class="max-w-[1200px] mx-auto px-6 relative z-10">

    <!-- Section Header -->
    <div class="text-center mb-20 md:mb-28">
      <!-- Eyebrow -->
      <div class="inline-flex items-center gap-2 mb-6">
        <div class="w-8 h-px bg-[#9fe870]/50"></div>
        <span class="text-[#9fe870] text-xs font-semibold tracking-[0.2em] uppercase">Process</span>
        <div class="w-8 h-px bg-[#9fe870]/50"></div>
      </div>

      <!-- Headline -->
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 tracking-tight">
        How It <span class="text-[#9fe870]">Works</span>
      </h2>

      <!-- Subtitle -->
      <p class="text-white/50 text-lg md:text-xl max-w-xl mx-auto leading-relaxed">
        Three steps to start earning rebates from your trading volume
      </p>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-6 relative">

      <!-- Circuit connector lines (desktop) -->
      <div class="hidden md:block absolute top-[88px] left-[calc(16.67%+40px)] right-[calc(16.67%+40px)] h-full pointer-events-none" aria-hidden="true">
        <!-- Main line -->
        <svg class="absolute inset-0 w-full h-8" viewBox="0 0 100 32" preserveAspectRatio="none">
          <path d="M0 16 L40 16 L40 0 L100 0" fill="none" stroke="url(#circuit-gradient)" stroke-width="1" stroke-dasharray="4 4" class="circuit-path"/>
          <path d="M0 16 L40 16 L40 0 L100 0" fill="none" stroke="url(#circuit-gradient)" stroke-width="1" opacity="0.3" class="circuit-glow"/>
        </svg>
        <svg class="absolute inset-0 w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="none">
          <defs>
            <linearGradient id="circuit-gradient" x1="0%" y1="0%" x2="100%" y2="0%">
              <stop offset="0%" stop-color="#9fe870" stop-opacity="0"/>
              <stop offset="20%" stop-color="#9fe870" stop-opacity="0.6"/>
              <stop offset="50%" stop-color="#9fe870" stop-opacity="1"/>
              <stop offset="80%" stop-color="#9fe870" stop-opacity="0.6"/>
              <stop offset="100%" stop-color="#9fe870" stop-opacity="0"/>
            </linearGradient>
          </defs>
        </svg>

        <!-- Node dots -->
        <div class="absolute left-[38%] top-1/2 -translate-y-1/2 w-2 h-2 bg-[#9fe870] rounded-full animate-pulse-slow"></div>
        <div class="absolute right-[38%] top-1/2 -translate-y-1/2 w-2 h-2 bg-[#9fe870] rounded-full animate-pulse-slow" style="animation-delay: 0.5s"></div>
      </div>

      <!-- Step 1 -->
      <div class="step-card" data-step="1">
        <div class="relative bg-[rgba(255,255,255,0.02)] border border-[rgba(159,232,112,0.15)] rounded-[24px] p-8 md:p-10 overflow-hidden group">
          <!-- Scan line effect on hover -->
          <div class="scan-line" aria-hidden="true"></div>

          <!-- Glow corner -->
          <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-[#9fe870]/10 to-transparent rounded-bl-[100px] opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

          <!-- Step index -->
          <div class="flex items-center gap-4 mb-8">
            <div class="step-number">01</div>
            <div class="flex-1 h-px bg-gradient-to-r from-[#9fe870]/30 to-transparent"></div>
          </div>

          <!-- Icon container -->
          <div class="w-16 h-16 mb-8 relative">
            <div class="absolute inset-0 bg-[#9fe870]/10 rounded-2xl blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="relative w-full h-full bg-[rgba(159,232,112,0.1)] border border-[rgba(159,232,112,0.2)] rounded-2xl flex items-center justify-center">
              <svg class="w-7 h-7 text-[#9fe870]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
              </svg>
            </div>
          </div>

          <!-- Content -->
          <h3 class="text-xl md:text-2xl font-semibold text-white mb-4 tracking-tight">
            {t(locale, 'howItWorks.step1Title')}
          </h3>
          <p class="text-white/50 text-base md:text-lg leading-relaxed">
            {t(locale, 'howItWorks.step1Desc')}
          </p>

          <!-- Corner decoration -->
          <div class="absolute bottom-0 left-0 w-4 h-4 border-l border-b border-[rgba(159,232,112,0.2)] rounded-bl-lg"></div>
          <div class="absolute bottom-0 right-0 w-4 h-4 border-r border-b border-[rgba(159,232,112,0.2)] rounded-br-lg"></div>
        </div>
      </div>

      <!-- Step 2 -->
      <div class="step-card" data-step="2">
        <div class="relative bg-[rgba(255,255,255,0.02)] border border-[rgba(159,232,112,0.15)] rounded-[24px] p-8 md:p-10 overflow-hidden group">
          <div class="scan-line" aria-hidden="true"></div>
          <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-[#9fe870]/10 to-transparent rounded-bl-[100px] opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

          <div class="flex items-center gap-4 mb-8">
            <div class="step-number">02</div>
            <div class="flex-1 h-px bg-gradient-to-r from-[#9fe870]/30 to-transparent"></div>
          </div>

          <div class="w-16 h-16 mb-8 relative">
            <div class="absolute inset-0 bg-[#9fe870]/10 rounded-2xl blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="relative w-full h-full bg-[rgba(159,232,112,0.1)] border border-[rgba(159,232,112,0.2)] rounded-2xl flex items-center justify-center">
              <svg class="w-7 h-7 text-[#9fe870]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
              </svg>
            </div>
          </div>

          <h3 class="text-xl md:text-2xl font-semibold text-white mb-4 tracking-tight">
            {t(locale, 'howItWorks.step2Title')}
          </h3>
          <p class="text-white/50 text-base md:text-lg leading-relaxed">
            {t(locale, 'howItWorks.step2Desc')}
          </p>

          <div class="absolute bottom-0 left-0 w-4 h-4 border-l border-b border-[rgba(159,232,112,0.2)] rounded-bl-lg"></div>
          <div class="absolute bottom-0 right-0 w-4 h-4 border-r border-b border-[rgba(159,232,112,0.2)] rounded-br-lg"></div>
        </div>
      </div>

      <!-- Step 3 -->
      <div class="step-card" data-step="3">
        <div class="relative bg-[rgba(255,255,255,0.02)] border border-[rgba(159,232,112,0.15)] rounded-[24px] p-8 md:p-10 overflow-hidden group">
          <div class="scan-line" aria-hidden="true"></div>
          <div class="absolute top-0 right-0 w-32 h-32 bg-gradient-to-br from-[#9fe870]/10 to-transparent rounded-bl-[100px] opacity-0 group-hover:opacity-100 transition-opacity duration-700"></div>

          <div class="flex items-center gap-4 mb-8">
            <div class="step-number">03</div>
            <div class="flex-1 h-px bg-gradient-to-r from-[#9fe870]/30 to-transparent"></div>
          </div>

          <div class="w-16 h-16 mb-8 relative">
            <div class="absolute inset-0 bg-[#9fe870]/10 rounded-2xl blur-xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            <div class="relative w-full h-full bg-[rgba(159,232,112,0.1)] border border-[rgba(159,232,112,0.2)] rounded-2xl flex items-center justify-center">
              <svg class="w-7 h-7 text-[#9fe870]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
              </svg>
            </div>
          </div>

          <h3 class="text-xl md:text-2xl font-semibold text-white mb-4 tracking-tight">
            {t(locale, 'howItWorks.step3Title')}
          </h3>
          <p class="text-white/50 text-base md:text-lg leading-relaxed">
            {t(locale, 'howItWorks.step3Desc')}
          </p>

          <div class="absolute bottom-0 left-0 w-4 h-4 border-l border-b border-[rgba(159,232,112,0.2)] rounded-bl-lg"></div>
          <div class="absolute bottom-0 right-0 w-4 h-4 border-r border-b border-[rgba(159,232,112,0.2)] rounded-br-lg"></div>
        </div>
      </div>

    </div>

    <!-- Trust indicators -->
    <div class="mt-20 md:mt-24 flex flex-wrap items-center justify-center gap-8 md:gap-12">
      <div class="flex items-center gap-3 text-white/40">
        <div class="w-8 h-8 rounded-lg bg-[rgba(159,232,112,0.1)] border border-[rgba(159,232,112,0.2)] flex items-center justify-center">
          <svg class="w-4 h-4 text-[#9fe870]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
        </div>
        <span class="text-sm font-medium tracking-wide">256-bit Encrypted</span>
      </div>

      <div class="flex items-center gap-3 text-white/40">
        <div class="w-8 h-8 rounded-lg bg-[rgba(159,232,112,0.1)] border border-[rgba(159,232,112,0.2)] flex items-center justify-center">
          <svg class="w-4 h-4 text-[#9fe870]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
        </div>
        <span class="text-sm font-medium tracking-wide">SOC 2 Certified</span>
      </div>

      <div class="flex items-center gap-3 text-white/40">
        <div class="w-8 h-8 rounded-lg bg-[rgba(159,232,112,0.1)] border border-[rgba(159,232,112,0.2)] flex items-center justify-center">
          <svg class="w-4 h-4 text-[#9fe870]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" />
          </svg>
        </div>
        <span class="text-sm font-medium tracking-wide">On-chain Verified</span>
      </div>
    </div>

  </div>
</section>

<script>
  // Intersection Observer for staggered scroll animations
  const observerOptions = {
    threshold: 0.15,
    rootMargin: '0px 0px -80px 0px'
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const cards = document.querySelectorAll('.step-card');
        cards.forEach((card, index) => {
          const el = card as HTMLElement;
          setTimeout(() => {
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
          }, 150 + (index * 120));
        });

        // Animate circuit path
        const paths = document.querySelectorAll('.circuit-path');
        paths.forEach(path => {
          (path as SVGElement).style.strokeDashoffset = '0';
        });

        observer.unobserve(entry.target);
      }
    });
  }, observerOptions);

  // Initialize cards as invisible
  document.querySelectorAll('.step-card').forEach(card => {
    const el = card as HTMLElement;
    el.style.opacity = '0';
    el.style.transform = 'translateY(40px)';
    el.style.transition = 'opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1)';
  });

  const section = document.getElementById('how-it-works');
  if (section) {
    observer.observe(section);
  }
</script>

<style>
  /* Dot grid background */
  .dot-grid {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(circle, rgba(159, 232, 112, 0.3) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse at center, black 20%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 20%, transparent 70%);
  }

  /* Step number styling */
  .step-number {
    font-family: 'JetBrains Mono', 'SF Mono', 'Fira Code', monospace;
    font-size: 2rem;
    font-weight: 700;
    color: #9fe870;
    letter-spacing: -0.02em;
    text-shadow: 0 0 30px rgba(159, 232, 112, 0.5);
    line-height: 1;
  }

  /* Circuit path animation */
  .circuit-path {
    stroke-dasharray: 200;
    stroke-dashoffset: 200;
    transition: stroke-dashoffset 1.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .circuit-glow {
    filter: blur(2px);
  }

  /* Scan line effect */
  .scan-line {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 100%;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(159, 232, 112, 0.03) 50%,
      transparent 100%
    );
    transform: translateY(-100%);
    pointer-events: none;
  }

  .step-card:hover .scan-line {
    animation: scan 0.8s ease-out forwards;
  }

  @keyframes scan {
    0% {
      transform: translateY(-100%);
    }
    100% {
      transform: translateY(100%);
    }
  }

  /* Card hover states */
  .step-card .relative {
    transition: border-color 0.4s ease, box-shadow 0.4s ease;
  }

  .step-card:hover .relative {
    border-color: rgba(159, 232, 112, 0.4);
    box-shadow:
      0 0 0 1px rgba(159, 232, 112, 0.1),
      0 0 60px rgba(159, 232, 112, 0.08),
      inset 0 1px 0 rgba(159, 232, 112, 0.1);
  }

  /* Pulse animation for dots */
  @keyframes pulse-slow {
    0%, 100% {
      opacity: 0.6;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.2);
    }
  }

  .animate-pulse-slow {
    animation: pulse-slow 2s ease-in-out infinite;
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .step-number {
      font-size: 1.75rem;
    }
  }

  /* Respect prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .step-card {
      transition: none;
    }
    .step-card[style] {
      opacity: 1 !important;
      transform: none !important;
    }
    .step-card:hover .relative {
      transition: none;
    }
    .scan-line {
      display: none;
    }
    .circuit-path {
      transition: none;
      stroke-dashoffset: 0;
    }
    .animate-pulse-slow {
      animation: none;
    }
  }
</style>
