---
import { t, getLocale } from '../i18n/utils';
import type { Locale } from '../i18n/utils';
import Globe from './Globe';

const locale: Locale = getLocale(Astro.request.url);
---

<section id="hero" class="min-h-screen bg-[#0f1619] flex items-center justify-center px-6 py-20 md:py-0 relative overflow-hidden">
  <!-- Background gradient overlay -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#0f1619] via-[#0f1619]/95 to-[#1a2a3a]/30 pointer-events-none" aria-hidden="true"></div>

  <!-- Grid pattern overlay -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" aria-hidden="true" style="background-image: linear-gradient(#9fe870 1px, transparent 1px), linear-gradient(90deg, #9fe870 1px, transparent 1px); background-size: 60px 60px;"></div>

  <div class="max-w-[1200px] mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center relative z-10 py-12 lg:py-0">

    <!-- Left Column: Text Content -->
    <div class="text-center lg:text-left">
      <!-- Eyebrow label -->
      <div class="inline-flex items-center gap-2 bg-[rgba(159,232,112,0.1)] border border-[rgba(159,232,112,0.3)] rounded-full px-4 py-2 mb-8 animate-fade-in-up">
        <span class="w-2 h-2 bg-[#9fe870] rounded-full animate-pulse"></span>
        <span class="text-[#9fe870] text-sm font-semibold tracking-wide">{t(locale, 'hero.eyebrow')}</span>
      </div>

      <!-- Main headline -->
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-[3.5rem] font-bold text-white leading-[1.1] mb-6 animate-fade-in-up" style="animation-delay: 100ms">
        {t(locale, 'hero.headline')}
      </h1>

      <!-- Subheadline -->
      <p class="text-lg md:text-xl text-white/70 leading-relaxed max-w-xl mx-auto lg:mx-0 mb-10 animate-fade-in-up" style="animation-delay: 200ms">
        {t(locale, 'hero.subheadline')}
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start animate-fade-in-up" style="animation-delay: 300ms">
        <!-- Primary CTA - Wise-style pill with scale and slip animation -->
        <a
          href="#cta"
          class="cta-primary bg-[#9fe870] text-[#163300] hover:scale-105 active:scale-95 px-8 py-4 font-semibold rounded-full min-h-12 transition-all duration-200 inline-flex items-center justify-center gap-2 relative overflow-hidden group"
        >
          <span class="relative z-10">{t(locale, 'hero.primaryCta')}</span>
          <svg class="w-5 h-5 relative z-10 transition-transform duration-200 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
          <!-- Slip shine effect -->
          <span class="slip-shine" aria-hidden="true"></span>
        </a>

        <!-- Secondary CTA - outline pill -->
        <a
          href="#how-it-works"
          class="cta-secondary bg-transparent text-white hover:bg-[rgba(159,232,112,0.1)] hover:scale-105 active:scale-95 px-8 py-4 font-semibold rounded-full min-h-12 transition-all duration-200 border border-white/30 inline-flex items-center justify-center gap-2"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
          </svg>
          {t(locale, 'hero.secondaryCta')}
        </a>
      </div>

      <!-- Trust indicators -->
      <div class="flex flex-wrap items-center justify-center lg:justify-start gap-6 mt-10 text-white/50 text-sm animate-fade-in-up" style="animation-delay: 400ms">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[#9fe870]" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          <span>{t(locale, 'hero.trustKyc')}</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[#9fe870]" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          <span>{t(locale, 'hero.trustNoFees')}</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-[#9fe870]" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
          <span>{t(locale, 'hero.trustOnchain')}</span>
        </div>
      </div>
    </div>

    <!-- Right Column: Globe Animation -->
    <div class="hidden lg:flex items-center justify-center relative animate-fade-in-up" style="animation-delay: 250ms" aria-hidden="true">
      <Globe client:load />
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 animate-bounce-subtle" aria-hidden="true">
    <span class="text-white/40 text-xs tracking-wider">{t(locale, 'hero.scrollHint')}</span>
    <svg class="w-5 h-5 text-white/40" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>

<style>
  /* Fade-in and slide-up animation */
  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-in-up {
    animation: fade-in-up 0.7s ease-out forwards;
    opacity: 0;
  }

  /* Subtle bounce for visual elements */
  @keyframes bounce-subtle {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-4px);
    }
  }

  .animate-bounce-subtle {
    animation: bounce-subtle 2s ease-in-out infinite;
  }

  /* Floating particles */
  @keyframes float {
    0%, 100% {
      transform: translateY(0) scale(1);
      opacity: 1;
    }
    50% {
      transform: translateY(-10px) scale(1.2);
      opacity: 0.6;
    }
  }

  .animate-float {
    animation: float 3s ease-in-out infinite;
  }

  /* Progress bar animation */
  @keyframes progress-bar {
    from {
      width: 0%;
    }
    to {
      width: 75%;
    }
  }

  .animate-progress-bar {
    animation: progress-bar 1.5s ease-out forwards;
  }

  /* Primary CTA slip shine effect */
  .cta-primary .slip-shine {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      105deg,
      transparent 40%,
      rgba(255, 255, 255, 0.4) 50%,
      transparent 60%
    );
    transform: translateX(-150%);
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    border-radius: inherit;
  }

  .cta-primary:hover .slip-shine {
    transform: translateX(150%);
  }

  .cta-primary:hover {
    filter: brightness(1.08);
    box-shadow: 0 0 30px rgba(159, 232, 112, 0.3);
  }

  /* Pulse animation for the eyebrow dot */
  @keyframes pulse-glow {
    0%, 100% {
      box-shadow: 0 0 0 0 rgba(159, 232, 112, 0.4);
    }
    50% {
      box-shadow: 0 0 0 6px rgba(159, 232, 112, 0);
    }
  }

  .animate-pulse {
    animation: pulse-glow 2s ease-in-out infinite;
  }

  /* Respect prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .animate-fade-in-up,
    .animate-bounce-subtle,
    .animate-float,
    .animate-progress-bar,
    .animate-pulse {
      animation: none;
      opacity: 1;
      transform: none;
    }
    .cta-primary .slip-shine {
      display: none;
    }
    .cta-primary,
    .cta-secondary {
      transition: none;
    }
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .animate-fade-in-up {
      animation-duration: 0.5s;
    }
  }
</style>