---
import { t, getLocale } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

const locale: Locale = getLocale(Astro.request.url);
---

<section id="hero" class="min-h-screen bg-[#1E3A5F] flex items-center justify-center px-6">
  <div class="text-center max-w-3xl mx-auto">
    <h1 class="text-4xl md:text-6xl font-bold text-white mb-6 leading-tight">
      {t(locale, 'hero.headline')}
    </h1>
    <p class="text-lg md:text-xl text-white/80 mb-8 leading-relaxed max-w-2xl mx-auto">
      {t(locale, 'hero.subheadline')}
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center">
      <a href="#how-it-works" class="inline-flex items-center justify-center px-8 py-3 bg-[#1A6B2E] text-white font-semibold rounded-lg min-h-12 hover:bg-[#155a24] transition-colors">
        {t(locale, 'hero.primaryCta')}
      </a>
      <a href="#how-it-works" class="inline-flex items-center justify-center px-8 py-3 bg-white/10 text-white font-semibold rounded-lg min-h-12 hover:bg-white/20 transition-colors border border-white/20">
        {t(locale, 'hero.secondaryCta')}
      </a>
    </div>
  </div>
</section>