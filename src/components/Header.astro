---
import { t, getLocale } from '../i18n/utils';
import type { Locale } from '../i18n/utils';
import Logo from '../assets/logo.png';

const locale: Locale = getLocale(Astro.request.url);
---

<header class="sticky top-0 z-50 bg-[#0f1619] border-b border-white/[0.08]">
  <div class="max-w-[1200px] mx-auto px-6 h-16 flex items-center justify-between gap-6">
    <!-- Logo -->
    <a href="/" class="logo-link flex items-center gap-3 no-underline flex-shrink-0 hover:opacity-80 transition-opacity duration-200" aria-label="Zentrix Home">
      <img src={Logo.src} alt="Zentrix" width="150" height="150" class="logo-img rounded-lg transition-transform duration-200 hover:scale-105" />
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-1" aria-label="Main navigation">
      <a href="#how-it-works" class="nav-link text-white/85 px-4 py-2 text-sm font-semibold transition-all duration-200 min-h-11 flex items-center relative after:absolute after:bottom-0 after:left-0 after:w-full after:h-0.5 after:bg-[#9fe870] after:scale-x-0 after:origin-left after:transition-transform after:duration-300 hover:after:scale-x-100 hover:after:shadow-[0_0_8px_#9fe870]">{t(locale, 'header.navHowItWorks')}</a>
      <a href="#why-zentrix" class="nav-link text-white/85 px-4 py-2 text-sm font-semibold transition-all duration-200 min-h-11 flex items-center relative after:absolute after:bottom-0 after:left-0 after:w-full after:h-0.5 after:bg-[#9fe870] after:scale-x-0 after:origin-left after:transition-transform after:duration-300 hover:after:scale-x-100 hover:after:shadow-[0_0_8px_#9fe870]">{t(locale, 'header.navWhyZentrix')}</a>
      <a href="#referral" class="nav-link text-white/85 px-4 py-2 text-sm font-semibold transition-all duration-200 min-h-11 flex items-center relative after:absolute after:bottom-0 after:left-0 after:w-full after:h-0.5 after:bg-[#9fe870] after:scale-x-0 after:origin-left after:transition-transform after:duration-300 hover:after:scale-x-100 hover:after:shadow-[0_0_8px_#9fe870]">{t(locale, 'header.navReferral')}</a>
      <a href="#faq" class="nav-link text-white/85 px-4 py-2 text-sm font-semibold transition-all duration-200 min-h-11 flex items-center relative after:absolute after:bottom-0 after:left-0 after:w-full after:h-0.5 after:bg-[#9fe870] after:scale-x-0 after:origin-left after:transition-transform after:duration-300 hover:after:scale-x-100 hover:after:shadow-[0_0_8px_#9fe870]">{t(locale, 'header.navFAQ')}</a>
    </nav>

    <!-- CTA + Language Toggle + Mobile Menu -->
    <div class="flex items-center gap-3">
      <!-- Language Toggle -->
      <div class="flex bg-[rgba(255,255,255,0.1)] rounded-full p-0.5" role="group" aria-label="Language selector">
        <button
          class={`lang-btn ${locale === 'en' ? 'bg-[#9fe870] text-[#163300] scale-105' : 'text-white/60 hover:text-white hover:scale-105 active:scale-95'} px-3 py-1.5 rounded-full text-sm font-semibold transition-all duration-200 min-h-9 min-w-11 flex items-center justify-center`}
          data-lang="en"
          aria-pressed={locale === 'en' ? 'true' : 'false'}
          title="English"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="24" height="16" rx="2" fill="#012169"/>
            <path d="M0 0L24 16M24 0L0 16" stroke="white" stroke-width="2"/>
            <path d="M12 0V16M0 8H24" stroke="white" stroke-width="3"/>
            <path d="M12 0L15 6H9L12 0ZM12 16L9 10H15L12 16ZM0 8L6 5V11L0 8ZM24 8L18 5V11L24 8Z" fill="white"/>
          </svg>
        </button>
        <button
          class={`lang-btn ${locale === 'vi' ? 'bg-[#9fe870] text-[#163300] scale-105' : 'text-white/60 hover:text-white hover:scale-105 active:scale-95'} px-3 py-1.5 rounded-full text-sm font-semibold transition-all duration-200 min-h-9 min-w-11 flex items-center justify-center`}
          data-lang="vi"
          aria-pressed={locale === 'vi' ? 'true' : 'false'}
          title="Tiếng Việt"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 16" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect width="24" height="16" rx="2" fill="#DA251D"/>
            <path d="M12 3L13.5 7H18L14 10L15.5 14L12 11L8.5 14L10 10L6 7H10.5L12 3Z" fill="#FFEB00"/>
          </svg>
        </button>
      </div>

      <!-- Mobile hamburger -->
      <button class="hamburger flex flex-col justify-center gap-[5px] w-11 h-11 bg-transparent border-none cursor-pointer p-0 md:hidden" aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-nav">
        <span class="hamburger-line block w-6 h-0.5 bg-white/85 rounded transition-all duration-200 origin-center"></span>
        <span class="hamburger-line block w-6 h-0.5 bg-white/85 rounded transition-all duration-200"></span>
        <span class="hamburger-line block w-6 h-0.5 bg-white/85 rounded transition-all duration-200 origin-center"></span>
      </button>

       <!-- CTA Button (Wise-style pill) -->
      <a
        href="#cta"
        class="cta-btn bg-[#9fe870] text-[#163300] hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(159,232,112,0.4)] active:scale-95 px-5 py-2.5 rounded-full text-sm font-semibold transition-all duration-200 min-h-11 flex items-center hidden sm:flex"
      >
        {t(locale, 'header.navCTA')}
      </a>
    </div>
  </div>

  <!-- Mobile Nav -->
  <nav id="mobile-nav" class="mobile-nav hidden md:hidden bg-[#0f1619] border-t border-white/10 px-6 py-4 flex-col gap-2" aria-label="Mobile navigation">
    <a href="#how-it-works" class="nav-link-mobile text-white/85 no-underline text-base font-semibold py-3 min-h-11 flex items-center border-b border-white/10 rounded-lg px-2 transition-all duration-200 relative after:absolute after:bottom-2 after:left-2 after:w-[calc(100%-16px)] after:h-0.5 after:bg-[#9fe870] after:scale-x-0 after:origin-left after:transition-transform after:duration-300 hover:after:scale-x-100 hover:after:shadow-[0_0_8px_#9fe870]">{t(locale, 'header.navHowItWorks')}</a>
    <a href="#why-zentrix" class="nav-link-mobile text-white/85 no-underline text-base font-semibold py-3 min-h-11 flex items-center border-b border-white/10 rounded-lg px-2 transition-all duration-200 relative after:absolute after:bottom-2 after:left-2 after:w-[calc(100%-16px)] after:h-0.5 after:bg-[#9fe870] after:scale-x-0 after:origin-left after:transition-transform after:duration-300 hover:after:scale-x-100 hover:after:shadow-[0_0_8px_#9fe870]">{t(locale, 'header.navWhyZentrix')}</a>
    <a href="#referral" class="nav-link-mobile text-white/85 no-underline text-base font-semibold py-3 min-h-11 flex items-center border-b border-white/10 rounded-lg px-2 transition-all duration-200 relative after:absolute after:bottom-2 after:left-2 after:w-[calc(100%-16px)] after:h-0.5 after:bg-[#9fe870] after:scale-x-0 after:origin-left after:transition-transform after:duration-300 hover:after:scale-x-100 hover:after:shadow-[0_0_8px_#9fe870]">{t(locale, 'header.navReferral')}</a>
    <a href="#faq" class="nav-link-mobile text-white/85 no-underline text-base font-semibold py-3 min-h-11 flex items-center rounded-lg px-2 transition-all duration-200 relative after:absolute after:bottom-2 after:left-2 after:w-[calc(100%-16px)] after:h-0.5 after:bg-[#9fe870] after:scale-x-0 after:origin-left after:transition-transform after:duration-300 hover:after:scale-x-100 hover:after:shadow-[0_0_8px_#9fe870]">{t(locale, 'header.navFAQ')}</a>
    <!-- Mobile CTA -->
    <a href="#cta" class="cta-btn-mobile bg-[#9fe870] text-[#163300] hover:-translate-y-0.5 hover:shadow-[0_4px_20px_rgba(159,232,112,0.4)] active:scale-95 mt-2 px-5 py-3 rounded-full text-sm font-semibold transition-all duration-200 min-h-12 flex items-center justify-center">{t(locale, 'header.navCTA')}</a>
  </nav>
</header>

<style>
  /* Hamburger X morph animation */
  .hamburger.open .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .hamburger.open .hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .hamburger.open .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* CTA lift + glow is handled via Tailwind classes for cleaner separation */

  /* Respect prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .hamburger-line,
    .nav-link,
    .nav-link-mobile,
    .cta-btn,
    .cta-btn-mobile,
    .lang-btn,
    .logo-img {
      transition: none;
    }
  }
</style>

<script>
  const STORAGE_KEY = 'zentrix-locale';

  function setLocale(locale: string): void {
    localStorage.setItem(STORAGE_KEY, locale);
    const url = new URL(window.location.href);
    url.searchParams.set('lang', locale);
    window.location.href = url.toString();
  }

  document.querySelectorAll('.lang-btn').forEach((btn) => {
    btn.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const lang = target.dataset.lang;
      if (lang && (lang === 'en' || lang === 'vi')) {
        setLocale(lang);
      }
    });
  });

  const hamburger = document.querySelector('.hamburger');
  const mobileNav = document.querySelector('#mobile-nav');

  hamburger?.addEventListener('click', () => {
    const isExpanded = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!isExpanded));
    if (mobileNav) {
      (mobileNav as HTMLElement).style.display = isExpanded ? 'flex' : 'none';
    }
    hamburger.classList.toggle('open');
  });

  document.querySelectorAll('.nav-link-mobile').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger?.setAttribute('aria-expanded', 'false');
      if (mobileNav) {
        (mobileNav as HTMLElement).style.display = 'none';
      }
      hamburger?.classList.remove('open');
    });
  });
</script>