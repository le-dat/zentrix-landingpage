---
import '../styles/global.css';

const { title = "Zentrix" } = Astro.props;
---

<!doctype html>
<html lang="en" dir="ltr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<!-- Prevent FOUC: set lang before paint -->
		<script is:inline>
			(function () {
				var lang = localStorage.getItem('zentrix-locale');
				if (lang === 'vi' || lang === 'en') {
					document.documentElement.lang = lang;
				} else {
					var browserLang = navigator.language.split('-')[0];
					document.documentElement.lang = browserLang === 'vi' ? 'vi' : 'en';
				}
			})();
		</script>
	</head>
	<body class="antialiased bg-[#0f1619]">
		<slot />
	</body>
</html>