---
import { t, getLocale } from '../i18n/utils';
import type { Locale } from '../i18n/utils';

const locale: Locale = getLocale(Astro.request.url);
---

<section id="why-zentrix" class="py-20 md:py-28 bg-[#F4F4F4] relative overflow-hidden">
  <!-- Subtle grid pattern -->
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" aria-hidden="true"
    style="background-image: linear-gradient(#0f1619 1px, transparent 1px), linear-gradient(90deg, #0f1619 1px, transparent 1px); background-size: 40px 40px;">
  </div>

  <div class="max-w-[1200px] mx-auto px-6 relative z-10">

    <!-- Section Header -->
    <div class="text-center mb-14">
      <span class="inline-block text-[#9fe870] text-sm font-semibold tracking-wider uppercase mb-4">
        {t(locale, 'why.badge')}
      </span>
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-[#0f1619] mb-4">
        {t(locale, 'why.title')}
      </h2>
      <p class="text-[#868685] text-lg md:text-xl max-w-2xl mx-auto">
        {t(locale, 'why.subtitle')}
      </p>
    </div>

    <!-- 2x2 Feature Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5 md:gap-6">

      <!-- On-chain Transparency -->
      <div class="why-card bg-white rounded-[30px] p-7 md:p-8 relative overflow-hidden group" data-feature="onchain">
        <div class="absolute -top-12 -right-12 w-24 h-24 bg-[#9fe870]/10 rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative">
          <div class="w-16 h-16 mb-6 bg-[#9fe870]/10 rounded-2xl flex items-center justify-center border border-[#9fe870]/20">
            <svg class="w-8 h-8 text-[#9fe870]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
            </svg>
          </div>
          <h3 class="text-[#0f1619] text-xl md:text-2xl font-semibold mb-3 leading-tight">
            {t(locale, 'why.onchainTitle')}
          </h3>
          <p class="text-[#868685] text-base md:text-lg leading-relaxed">
            {t(locale, 'why.onchainDesc')}
          </p>
        </div>
      </div>

      <!-- Multi-Broker Support -->
      <div class="why-card bg-white rounded-[30px] p-7 md:p-8 relative overflow-hidden group" data-feature="multibroker">
        <div class="absolute -top-12 -right-12 w-24 h-24 bg-[#9fe870]/10 rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative">
          <div class="w-16 h-16 mb-6 bg-[#9fe870]/10 rounded-2xl flex items-center justify-center border border-[#9fe870]/20">
            <svg class="w-8 h-8 text-[#9fe870]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </div>
          <h3 class="text-[#0f1619] text-xl md:text-2xl font-semibold mb-3 leading-tight">
            {t(locale, 'why.multiBrokerTitle')}
          </h3>
          <p class="text-[#868685] text-base md:text-lg leading-relaxed">
            {t(locale, 'why.multiBrokerDesc')}
          </p>
        </div>
      </div>

      <!-- Clear Referral Network -->
      <div class="why-card bg-white rounded-[30px] p-7 md:p-8 relative overflow-hidden group" data-feature="refnetwork">
        <div class="absolute -top-12 -right-12 w-24 h-24 bg-[#9fe870]/10 rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative">
          <div class="w-16 h-16 mb-6 bg-[#9fe870]/10 rounded-2xl flex items-center justify-center border border-[#9fe870]/20">
            <svg class="w-8 h-8 text-[#9fe870]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-[#0f1619] text-xl md:text-2xl font-semibold mb-3 leading-tight">
            {t(locale, 'why.refNetworkTitle')}
          </h3>
          <p class="text-[#868685] text-base md:text-lg leading-relaxed">
            {t(locale, 'why.refNetworkDesc')}
          </p>
        </div>
      </div>

      <!-- Easy Withdrawals -->
      <div class="why-card bg-white rounded-[30px] p-7 md:p-8 relative overflow-hidden group" data-feature="withdraw">
        <div class="absolute -top-12 -right-12 w-24 h-24 bg-[#9fe870]/10 rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="relative">
          <div class="w-16 h-16 mb-6 bg-[#9fe870]/10 rounded-2xl flex items-center justify-center border border-[#9fe870]/20">
            <svg class="w-8 h-8 text-[#9fe870]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" />
            </svg>
          </div>
          <h3 class="text-[#0f1619] text-xl md:text-2xl font-semibold mb-3 leading-tight">
            {t(locale, 'why.easyWithdrawTitle')}
          </h3>
          <p class="text-[#868685] text-base md:text-lg leading-relaxed">
            {t(locale, 'why.easyWithdrawDesc')}
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .why-card {
    transition: transform 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                box-shadow 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94),
                border-color 0.3s ease;
    border: 1px solid rgba(0, 0, 0, 0.06);
  }

  .why-card::before {
    content: '';
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, transparent 40%, rgba(159, 232, 112, 0.3) 100%);
    -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .why-card:hover {
    transform: translateY(-4px) scale(1.01);
    box-shadow: 0 20px 40px rgba(159, 232, 112, 0.1), 0 0 0 1px rgba(159, 232, 112, 0.15);
    border-color: rgba(159, 232, 112, 0.2);
  }

  .why-card:hover::before {
    opacity: 1;
  }

  .why-card:active {
    transform: translateY(-2px) scale(0.99);
    transition-duration: 0.1s;
  }

  /* Respect prefers-reduced-motion */
  @media (prefers-reduced-motion: reduce) {
    .why-card {
      transition: none;
    }
    .why-card:hover {
      transform: none;
      box-shadow: none;
    }
    .why-card:hover::before {
      opacity: 0;
    }
    .why-card:active {
      transform: none;
    }
  }

  /* Mobile touch optimization */
  @media (hover: none) {
    .why-card:hover {
      transform: none;
      box-shadow: none;
    }
    .why-card:active {
      transform: scale(0.98);
    }
  }
</style>
